# Copy this file to .env (local) or set these as real secrets on the server / in GitHub Actions.
# Never commit an actual .env file with real values.

# MySQL root password (used by both the mysql container and the backend's DB_PASSWORD)
DB_PASSWORD=change_this_password

# JWT signing secret - must be at least 32 bytes, random, and kept secret
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_bytes

# Only used by docker-compose.prod.yml - full ECR image URIs, set by the CI/CD pipeline
BACKEND_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/ems-backend:latest
FRONTEND_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/ems-frontend:latest
